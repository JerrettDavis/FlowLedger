# FlowLedger environment variable template.
# Copy to .env for local docker-compose use.
# NEVER commit .env with real values.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=replace_with_strong_password

# ── Connection strings (used when NOT running via Aspire) ─────────────────────
# These are injected directly into the app containers via docker-compose.
# Not required when running infra-only (Aspire sets them automatically).
ConnectionStrings__flowledger=Host=postgres;Port=5432;Database=flowledger;Username=flowledger;Password=replace_with_strong_password
ConnectionStrings__redis=redis:6379

# ── API authentication (full-stack profile) ───────────────────────────────────
# Required when running the full stack outside Aspire (docker compose --profile full).
# Use the dev default for local dev; generate a strong random key for production:
#   openssl rand -hex 32
API__KEY=dev-local-key-not-for-production

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# Aspire provides an OTLP collector automatically in dev.
# Set this to forward traces/metrics to an external collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
