# FlowLedger environment variable template.
# Copy to .env for local docker-compose use.
# NEVER commit .env with real values.

# PostgreSQL
POSTGRES_PASSWORD=replace_with_strong_password

# Connection strings (used when NOT running via Aspire)
ConnectionStrings__flowledger=Host=localhost;Port=5432;Database=flowledger;Username=flowledger;Password=replace_with_strong_password
ConnectionStrings__redis=localhost:6379

# OpenTelemetry (optional — Aspire provides this automatically in dev)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
