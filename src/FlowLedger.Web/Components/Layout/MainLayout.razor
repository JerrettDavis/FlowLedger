@inherits LayoutComponentBase
@inject FlowLedger.Web.ApiClient.FlowLedgerApiClient ApiClient
@inject ISnackbar Snackbar

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" aria-label="FlowLedger application bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       aria-label="Toggle navigation drawer" />
        <MudText Typo="Typo.h6" Class="ml-2">FlowLedger</MudText>
        <MudSpacer />
        @if (_syncing)
        {
            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Indeterminate="true" Class="mr-2" aria-label="Syncing" />
        }
        <MudTooltip Text="Connect simulated provider and sync demo data">
            <MudButton StartIcon="@Icons.Material.Filled.CloudSync"
                       Color="Color.Inherit"
                       Variant="Variant.Text"
                       OnClick="ConnectAndSync"
                       Disabled="_syncing"
                       aria-label="Connect and sync demo data">
                Connect &amp; Sync
            </MudButton>
        </MudTooltip>
        <MudTooltip Text="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleTheme"
                           aria-label="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" aria-label="Main navigation">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Class="fw-bold">Navigation</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 px-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private bool _syncing = false;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => _isDarkMode = !_isDarkMode;

    private async Task ConnectAndSync()
    {
        _syncing = true;
        try
        {
            await ApiClient.ConnectAsync();
            var result = await ApiClient.SyncAsync();
            var msg = result is not null
                ? $"Sync complete — {result.AccountsSynced} accounts, {result.TransactionsSynced} transactions"
                : "Sync complete";
            Snackbar.Add(msg, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }
}
