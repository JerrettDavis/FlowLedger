@page "/accounts"
@rendermode InteractiveServer
@inject FlowLedger.Web.ApiClient.FlowLedgerApiClient ApiClient
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<Accounts> Logger

<PageTitle>Accounts — FlowLedger</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h4">Accounts</MudText>
    <MudButton StartIcon="@Icons.Material.Filled.Add"
               Color="Color.Primary"
               Variant="Variant.Filled"
               OnClick="OpenCreateDialog"
               aria-label="Add new account">
        Add Account
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" aria-label="Loading accounts" />
}
@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" aria-live="assertive">@_error</MudAlert>
}

<MudDataGrid T="FlowLedger.Web.ApiClient.AccountDto"
             Items="_accounts"
             Filterable="true"
             FilterMode="DataGridFilterMode.ColumnFilterRow"
             SortMode="SortMode.Multiple"
             Hover="true"
             Striped="true"
             Dense="false"
             aria-label="Accounts table">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" Sortable="true" />
        <PropertyColumn Property="x => x.AccountType" Title="Type" Sortable="true" />
        <PropertyColumn Property="x => x.Institution" Title="Institution" Sortable="true" />
        <TemplateColumn Title="Balance" Sortable="true" SortBy="x => x.BalanceAmount">
            <CellTemplate>
                <MudText Color="@(context.Item.BalanceAmount >= 0 ? Color.Default : Color.Error)">
                    @context.Item.BalanceAmount.ToString("C2")
                </MudText>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.BalanceCurrency" Title="Currency" />
        <TemplateColumn Title="Status">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                    @(context.Item.IsActive ? "Active" : "Inactive")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Size="Size.Small"
                               Color="Color.Primary"
                               OnClick="() => OpenEditDialog(context.Item)"
                               aria-label="@($"Edit account {context.Item.Name}")" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private bool _loading = true;
    private string? _error;
    private List<FlowLedger.Web.ApiClient.AccountDto> _accounts = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _accounts = await ApiClient.GetAccountsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load accounts");
            _error = ex is FlowLedger.Web.ApiClient.ApiClientException ace
                ? ace.Message
                : "Failed to load accounts. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<AccountFormDialog>("Create Account",
            new DialogParameters<AccountFormDialog> { { x => x.Account, null } });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: FlowLedger.Web.ApiClient.CreateAccountRequest req })
        {
            try
            {
                await ApiClient.CreateAccountAsync(req);
                Snackbar.Add("Account created", Severity.Success);
                await LoadAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to create account");
                Snackbar.Add(ex is FlowLedger.Web.ApiClient.ApiClientException ? ex.Message : "Couldn't create account. Please try again.", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(FlowLedger.Web.ApiClient.AccountDto account)
    {
        var dialog = await DialogService.ShowAsync<AccountFormDialog>("Edit Account",
            new DialogParameters<AccountFormDialog> { { x => x.Account, account } });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: FlowLedger.Web.ApiClient.UpdateAccountRequest req })
        {
            try
            {
                await ApiClient.UpdateAccountAsync(account.Id, req);
                Snackbar.Add("Account updated", Severity.Success);
                await LoadAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to update account {AccountId}", account.Id);
                Snackbar.Add(ex is FlowLedger.Web.ApiClient.ApiClientException ? ex.Message : "Couldn't update account. Please try again.", Severity.Error);
            }
        }
    }
}
