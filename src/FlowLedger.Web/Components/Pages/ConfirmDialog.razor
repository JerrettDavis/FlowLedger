<MudDialog aria-labelledby="confirm-dialog-title">
    <TitleContent>
        <MudText Typo="Typo.h6" id="confirm-dialog-title">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>@ContentText</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" aria-label="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Error" OnClick="Confirm" Variant="Variant.Filled"
                   aria-label="@ConfirmText">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Title { get; set; } = "Confirm";
    [Parameter] public string ContentText { get; set; } = "Are you sure?";
    [Parameter] public string ConfirmText { get; set; } = "OK";

    private void Cancel() => MudDialog.Cancel();
    private void Confirm() => MudDialog.Close(DialogResult.Ok(true));
}
