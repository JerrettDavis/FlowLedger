@page "/"

<PageTitle>Dashboard — FlowLedger</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">
    Know where your money went, where it is going, and when your plans become possible.
</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.overline">Milestone 0</MudText>
                <MudText Typo="Typo.h6">Foundation Complete</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">
                    Solution scaffold, Aspire orchestration, CI, and one-script run are ready.
                    Domain logic and UI features arrive in subsequent milestones.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.overline">Stack</MudText>
                <MudText Typo="Typo.h6">.NET 10 + Aspire + Blazor</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">
                    PostgreSQL, Redis, MudBlazor, EF Core, OpenIddict, Quartz, Serilog, OpenTelemetry.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.overline">License</MudText>
                <MudText Typo="Typo.h6">AGPL-3.0</MudText>
                <MudText Typo="Typo.body2" Class="mt-2">
                    Free and open source. Self-host first. SaaS-ready without SaaS lock-in.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
