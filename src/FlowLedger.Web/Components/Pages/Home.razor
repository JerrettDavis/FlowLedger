@page "/"
@rendermode InteractiveServer
@inject FlowLedger.Web.ApiClient.FlowLedgerApiClient ApiClient
@inject ILogger<Home> Logger

<PageTitle>Dashboard — FlowLedger</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" aria-live="assertive">@_error</MudAlert>
}

@if (_loading)
{
    <div aria-label="Loading dashboard">
        <!-- KPI skeleton row -->
        <MudGrid Class="mb-4">
            <MudItem xs="12" md="6">
                <CardSkeleton Height="120px" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <CardSkeleton Height="120px" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <CardSkeleton Height="120px" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <CardSkeleton Height="120px" />
            </MudItem>
        </MudGrid>
        <!-- Chart + flows skeleton row -->
        <MudGrid>
            <MudItem xs="12" md="8">
                <CardSkeleton Height="300px" />
            </MudItem>
            <MudItem xs="12" md="4">
                <CardSkeleton Height="300px" />
            </MudItem>
        </MudGrid>
    </div>
}
else
{
    <!-- Summary cards -->
    <MudGrid Class="mb-4">

        <!-- Hero: Total Balance -->
        <MudItem xs="12" md="6">
            <MudCard Class="fl-hero fl-card-hover fl-enter fl-enter-1">
                <MudCardContent>
                    <MudText Typo="Typo.overline" Color="Color.Primary">Total Balance</MudText>
                    <MudText Typo="Typo.h3" Class="fl-num" aria-label="Total balance">@Format.Money(_totalBalance)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Across @_accounts.Count account(s)</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Net Worth -->
        <MudItem xs="12" sm="6" md="2">
            <MudCard Class="fl-card-hover fl-enter fl-enter-2">
                <MudCardContent>
                    <MudText Typo="Typo.overline" Color="Color.Secondary">Net Worth</MudText>
                    <MudText Typo="Typo.h5" Class="fl-num" Color="@Format.Delta(_netWorth)" aria-label="Net worth">@Format.Money(_netWorth)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Assets minus liabilities</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Forecast Low -->
        <MudItem xs="12" sm="6" md="2">
            <MudCard Class="fl-card-hover fl-enter fl-enter-3">
                <MudCardContent>
                    <MudText Typo="Typo.overline" Color="@(_lowWaterMark < 0 ? Color.Error : Color.Warning)">Forecast Low</MudText>
                    <MudText Typo="Typo.h5" Class="fl-num" Color="@Format.Delta(_lowWaterMark)" aria-label="Forecast low water mark">@Format.Money(_lowWaterMark)</MudText>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(_lowWaterMarkDate.HasValue ? $"on {Format.DayMonth(_lowWaterMarkDate.Value)}" : "3-month horizon")
                        </MudText>
                        @if (_lowWaterMark < 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Class="pa-0" Style="height:18px;font-size:10px">Below zero</MudChip>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Overdraft Risk -->
        <MudItem xs="12" sm="6" md="2">
            <MudCard Class="fl-card-hover fl-enter fl-enter-4">
                <MudCardContent>
                    <MudText Typo="Typo.overline" Color="@(_overdraftCount > 0 ? Color.Error : Color.Success)">Overdraft Risk</MudText>
                    <MudText Typo="Typo.h5" Class="fl-num" Color="@(_overdraftCount > 0 ? Color.Error : Color.Success)" aria-label="Overdraft warnings">
                        @(_overdraftCount > 0 ? $"{_overdraftCount} warning(s)" : "None")
                    </MudText>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Next 3 months</MudText>
                        @if (_overdraftCount > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Class="pa-0" Style="height:18px;font-size:10px">
                                <MudIcon Icon="@Icons.Material.Outlined.Warning" Size="Size.Small" />
                            </MudChip>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>

    <MudGrid>
        <!-- Balance Projection Chart -->
        <MudItem xs="12" md="8">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Balance Projection</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">3-month household cash balance forecast</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_forecastPoints.Count >= 2)
                    {
                        <div style="height:220px;overflow:hidden" role="img" aria-label="Balance projection chart">
                            @((MarkupString)SvgChart.BuildBalanceProjection(
                                _forecastPoints,
                                zeroLine: 0m,
                                breaches: _breachDates,
                                lowWaterMark: _lwmTuple))
                        </div>
                    }
                    else
                    {
                        <EmptyState Icon="@Icons.Material.Outlined.ShowChart"
                                    Title="No forecast yet"
                                    Description="Click &quot;Connect &amp; Sync&quot; to load demo data." />
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Upcoming Flows -->
        <MudItem xs="12" md="4">
            <MudCard Style="height:100%">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Upcoming Flows</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Next 14 days</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Style="max-height:260px;overflow-y:auto">
                    @if (_upcomingFlows.Count > 0)
                    {
                        <MudList T="UpcomingFlow" Dense="true" aria-label="Upcoming flows list">
                            @foreach (var f in _upcomingFlows)
                            {
                                <MudListItem>
                                    <div class="d-flex justify-space-between align-center w-100">
                                        <div>
                                            <MudText Typo="Typo.body2" Style="font-weight:500">@f.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Format.DayMonth(f.Date)</MudText>
                                        </div>
                                        <MudText Typo="Typo.body2" Class="fl-num" Color="@Format.Delta(f.IsCredit ? f.Amount : -f.Amount)">
                                            @Format.Signed(f.IsCredit ? f.Amount : -f.Amount)
                                        </MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                    else
                    {
                        <EmptyState Icon="@Icons.Material.Outlined.CalendarMonth"
                                    Title="No upcoming flows"
                                    Description="No scheduled transactions in the next 14 days." />
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Overdraft Warnings detail -->
        @if (_overdraftWarnings.Count > 0)
        {
            <MudItem xs="12">
                <MudAlert Severity="Severity.Error" aria-live="assertive">
                    <MudText Typo="Typo.subtitle2">Overdraft Risk Detected</MudText>
                    @foreach (var w in _overdraftWarnings)
                    {
                        var acct = _accounts.FirstOrDefault(a => a.Id == w.AccountId);
                        <MudText Typo="Typo.body2">
                            @(acct?.Name ?? w.AccountId.ToString()) may go negative on @Format.FullDate(w.FirstBreachDate)
                            (projected: @Format.Money(w.ProjectedBalanceAmount))
                        </MudText>
                    }
                </MudAlert>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _loading = true;
    private string? _error;

    private List<FlowLedger.Web.ApiClient.AccountDto> _accounts = [];
    private decimal _totalBalance;
    private decimal _netWorth;
    private decimal _lowWaterMark;
    private DateOnly? _lowWaterMarkDate;
    private int _overdraftCount;
    private List<FlowLedger.Web.ApiClient.OverdraftWarningDto> _overdraftWarnings = [];
    private List<FlowLedger.Web.ApiClient.AggregateForecastPointDto> _forecastSeries = [];
    private List<UpcomingFlow> _upcomingFlows = [];

    // Derived collections for SvgChart
    private IReadOnlyList<(DateOnly date, decimal balance)> _forecastPoints = [];
    private IReadOnlyList<DateOnly>? _breachDates;
    private (DateOnly date, decimal balance)? _lwmTuple;

    private record UpcomingFlow(string Name, DateOnly Date, decimal Amount, bool IsCredit);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _accounts = await ApiClient.GetAccountsAsync();

            // Net worth: assets (positive balance accounts) minus liabilities
            _totalBalance = _accounts.Sum(a => a.BalanceAmount);
            var assetTypes = new[] { "Checking", "Savings", "Investment", "Cash", "ManualAsset" };
            var liabilityTypes = new[] { "CreditCard", "Loan", "Mortgage", "ManualLiability" };
            var assets = _accounts.Where(a => assetTypes.Contains(a.AccountType)).Sum(a => a.BalanceAmount);
            var liabilities = _accounts.Where(a => liabilityTypes.Contains(a.AccountType)).Sum(a => Math.Abs(a.BalanceAmount));
            _netWorth = assets - liabilities;

            // Forecast
            var forecast = await ApiClient.GetForecastAsync(months: 3);
            if (forecast is not null)
            {
                _forecastSeries = forecast.AggregateSeries;

                if (forecast.AggregateLowWaterMark is not null)
                {
                    _lowWaterMark = forecast.AggregateLowWaterMark.MinBalanceAmount;
                    _lowWaterMarkDate = forecast.AggregateLowWaterMark.Date;
                }

                _overdraftWarnings = forecast.OverdraftWarnings;
                _overdraftCount = _overdraftWarnings.Count;
            }

            // Map forecast series to typed tuples for SvgChart
            _forecastPoints = _forecastSeries
                .Select(p => (p.Date, p.BalanceAmount))
                .ToList();

            // Breach dates from overdraft warnings
            _breachDates = _overdraftWarnings.Count > 0
                ? _overdraftWarnings.Select(w => w.FirstBreachDate).Distinct().ToList()
                : null;

            // Low water mark tuple
            _lwmTuple = _lowWaterMarkDate.HasValue
                ? (_lowWaterMarkDate.Value, _lowWaterMark)
                : null;

            // Recurring flows for upcoming 14 days
            var flows = await ApiClient.GetRecurringFlowsAsync();
            var today = DateOnly.FromDateTime(DateTime.Today);
            var horizon = today.AddDays(14);

            foreach (var flow in flows.Where(f => f.IsActive))
            {
                for (var d = today; d <= horizon; d = d.AddDays(1))
                {
                    if (IsFlowOnDate(flow, d))
                    {
                        _upcomingFlows.Add(new UpcomingFlow(
                            flow.Name, d, flow.Amount, flow.Direction == "Credit"));
                    }
                }
            }

            _upcomingFlows = _upcomingFlows.OrderBy(f => f.Date).Take(20).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard data");
            _error = ex is FlowLedger.Web.ApiClient.ApiClientException ace
                ? ace.Message
                : "Failed to load dashboard data. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private static bool IsFlowOnDate(FlowLedger.Web.ApiClient.RecurringFlowDto flow, DateOnly date)
    {
        if (date < flow.StartDate) return false;
        if (flow.EndDate.HasValue && date > flow.EndDate) return false;

        return flow.RecurrenceFrequency switch
        {
            "Monthly" => flow.DayOfMonth.HasValue && date.Day == flow.DayOfMonth.Value,
            "Weekly" => flow.AnchorDayOfWeek is not null &&
                        date.DayOfWeek.ToString().Equals(flow.AnchorDayOfWeek, StringComparison.OrdinalIgnoreCase),
            "Daily" => true,
            _ => false
        };
    }
}
