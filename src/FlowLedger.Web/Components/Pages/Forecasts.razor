@page "/forecasts"
@rendermode InteractiveServer
@inject FlowLedger.Web.ApiClient.FlowLedgerApiClient ApiClient
@inject ISnackbar Snackbar
@inject ILogger<Forecasts> Logger

<PageTitle>Forecasts — FlowLedger</PageTitle>

<div class="d-flex align-center justify-space-between mb-4" style="flex-wrap:wrap;gap:8px">
    <MudText Typo="Typo.h4">Forecasts</MudText>
    <div class="d-flex align-center" style="gap:8px">
        <MudSelect @bind-Value="_horizonMonths" Label="Horizon" Style="width:140px"
                   aria-label="Forecast horizon in months">
            <MudSelectItem Value="1">1 month</MudSelectItem>
            <MudSelectItem Value="3">3 months</MudSelectItem>
            <MudSelectItem Value="6">6 months</MudSelectItem>
            <MudSelectItem Value="12">12 months</MudSelectItem>
        </MudSelect>
        <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                   Color="Color.Primary"
                   Variant="Variant.Outlined"
                   OnClick="LoadAsync"
                   aria-label="Run forecast">
            Run Forecast
        </MudButton>
    </div>
</div>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" aria-live="assertive">@_error</MudAlert>
}

@if (_loading)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3"><CardSkeleton Height="110px" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><CardSkeleton Height="110px" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><CardSkeleton Height="110px" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><CardSkeleton Height="110px" /></MudItem>
    </MudGrid>
    <CardSkeleton Height="260px" />
}
else if (_forecast is not null)
{
    <!-- Summary row -->
    <MudGrid Class="mb-4">
        <!-- Hero: Aggregate Low -->
        <MudItem xs="12" sm="6" md="3">
            <MudCard Class="fl-hero fl-card-hover fl-enter fl-enter-1">
                <MudCardContent>
                    <MudText Typo="Typo.overline">Aggregate Low</MudText>
                    <MudText Typo="Typo.h3" Class="fl-num"
                             Color="@(_forecast.AggregateLowWaterMark?.MinBalanceAmount < 0 ? Color.Error : Color.Default)"
                             aria-label="Aggregate low water mark">
                        @Format.Money(_forecast.AggregateLowWaterMark?.MinBalanceAmount ?? 0)
                    </MudText>
                    <MudText Typo="Typo.caption">
                        @(_forecast.AggregateLowWaterMark is not null
                            ? Format.FullDate(_forecast.AggregateLowWaterMark.Date)
                            : "–")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Overdraft Risk -->
        <MudItem xs="12" sm="6" md="3">
            <MudCard Class="fl-card-hover fl-enter fl-enter-2">
                <MudCardContent>
                    <MudText Typo="Typo.overline">Overdraft Risk</MudText>
                    <div class="d-flex align-center" style="gap:8px">
                        <MudText Typo="Typo.h5" Class="fl-num"
                                 Color="@(_forecast.OverdraftWarnings.Count > 0 ? Color.Error : Color.Success)">
                            @(_forecast.OverdraftWarnings.Count > 0
                                ? $"{_forecast.OverdraftWarnings.Count} warning{(_forecast.OverdraftWarnings.Count == 1 ? "" : "s")}"
                                : "None")
                        </MudText>
                        @if (_forecast.OverdraftWarnings.Count > 0)
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Warning" Color="Color.Error" Size="Size.Small" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Horizon -->
        <MudItem xs="12" sm="6" md="3">
            <MudCard Class="fl-card-hover fl-enter fl-enter-3">
                <MudCardContent>
                    <MudText Typo="Typo.overline">Horizon</MudText>
                    <MudText Typo="Typo.h5" Class="fl-num">
                        @Format.DayMonth(_forecast.HorizonStart)
                    </MudText>
                    <MudText Typo="Typo.caption">
                        → @Format.FullDate(_forecast.HorizonEnd)
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Accounts -->
        <MudItem xs="12" sm="6" md="3">
            <MudCard Class="fl-card-hover fl-enter fl-enter-4">
                <MudCardContent>
                    <MudText Typo="Typo.overline">Accounts</MudText>
                    <MudText Typo="Typo.h5" Class="fl-num">@_forecast.AccountSeries.Count</MudText>
                    <MudText Typo="Typo.caption">forecasted</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Overdraft warnings -->
    @if (_forecast.OverdraftWarnings.Count > 0)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" aria-live="assertive">
            <MudText Typo="Typo.subtitle2" Class="mb-1">Overdraft Risk</MudText>
            @foreach (var w in _forecast.OverdraftWarnings)
            {
                var acct = _accounts.FirstOrDefault(a => a.Id == w.AccountId);
                <MudText Typo="Typo.body2">
                    @(acct?.Name ?? w.AccountId.ToString()): projected balance
                    @Format.Money(w.ProjectedBalanceAmount) on @Format.FullDate(w.FirstBreachDate)
                </MudText>
            }
        </MudAlert>
    }

    <!-- Aggregate projection chart -->
    <MudCard Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Aggregate (Household) Balance</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (_forecast.AggregateSeries.Count > 0)
            {
                <div style="height:240px;overflow:hidden" role="img" aria-label="Aggregate balance projection chart">
                    @SvgChart.BuildBalanceProjection(
                        _forecast.AggregateSeries.Select(p => (p.Date, p.BalanceAmount)).ToList(),
                        zeroLine: 0m,
                        breaches: _forecast.OverdraftWarnings.Select(w => w.FirstBreachDate).ToList(),
                        lowWaterMark: _forecast.AggregateLowWaterMark is not null
                            ? (_forecast.AggregateLowWaterMark.Date, _forecast.AggregateLowWaterMark.MinBalanceAmount)
                            : null)
                </div>
            }
        </MudCardContent>
    </MudCard>

    <!-- Per-account series -->
    @foreach (var series in _forecast.AccountSeries)
    {
        var account = _accounts.FirstOrDefault(a => a.Id == series.AccountId);
        var lwm = _forecast.LowWaterMarks.FirstOrDefault(l => l.AccountId == series.AccountId);

        <MudExpansionPanel Text="@($"{account?.Name ?? series.AccountId.ToString()} — Low: {Format.Money(lwm?.MinBalanceAmount ?? series.StartingBalanceAmount)}")"
                           Dense="true" Class="mb-2">
            <MudDataGrid T="FlowLedger.Web.ApiClient.ForecastPointDto"
                         Items="series.Points"
                         Dense="true"
                         Hover="true"
                         aria-label="@($"{account?.Name} forecast series")">
                <Columns>
                    <TemplateColumn Title="Date" SortBy="x => x.Date">
                        <CellTemplate>@Format.DayMonth(context.Item.Date)</CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Balance">
                        <CellTemplate>
                            <MudText Class="fl-num"
                                     Color="@(context.Item.BalanceAmount < 0 ? Color.Error : Color.Default)"
                                     Typo="Typo.body2">
                                @Format.Money(context.Item.BalanceAmount)
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Net Change">
                        <CellTemplate>
                            <MudText Class="fl-num"
                                     Color="@(context.Item.NetChangeAmount >= 0 ? Color.Success : Color.Error)"
                                     Typo="Typo.body2">
                                @Format.Signed(context.Item.NetChangeAmount)
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Items">
                        <CellTemplate>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @string.Join(", ", context.Item.ContributingItems.Select(i => i.Label).Take(3))
                                @(context.Item.ContributingItems.Count > 3 ? $" +{context.Item.ContributingItems.Count - 3} more" : "")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </MudExpansionPanel>
    }
}
else
{
    <EmptyState Icon="@Icons.Material.Outlined.TrendingUp"
                Title="No forecast yet"
                Description="Click &quot;Connect &amp; Sync&quot; to load demo data, then run a forecast." />
}

@code {
    private bool _loading = true;
    private string? _error;
    private int _horizonMonths = 3;
    private FlowLedger.Web.ApiClient.ForecastResultDto? _forecast;
    private List<FlowLedger.Web.ApiClient.AccountDto> _accounts = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _accounts = await ApiClient.GetAccountsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load accounts for forecast page");
            Snackbar.Add("Couldn't load account names — account labels may be missing.", Severity.Warning);
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _forecast = await ApiClient.GetForecastAsync(months: _horizonMonths);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load forecast");
            _error = ex is FlowLedger.Web.ApiClient.ApiClientException ace
                ? ace.Message
                : "Failed to load forecast data. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}
